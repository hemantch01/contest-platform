# ─── Secrets (set these before deploying!) ───
JWT_SECRET=generate-a-strong-random-secret-here
CSRF_SECRET=generate-another-strong-random-secret

# ─── MongoDB ───
MONGO_URI=mongodb://mongo:27017/contest-platform

# ─── Redis ───
REDIS_URL=redis://redis:6379

# ─── Server ───
PORT=5000
NODE_ENV=production

# ─── Client ───
# Change 'localhost' to your domain/IP for EC2 deployment
NEXT_PUBLIC_API_URL=http://localhost/api
NEXT_PUBLIC_SOCKET_URL=ws://localhost/ws
